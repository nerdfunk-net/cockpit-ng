# Docker Compose Environment Variables
# Copy this file to .env and customize as needed

# Frontend Configuration
FRONTEND_PORT=3000

# Backend Configuration (backend port is fixed at 8000 inside the container)

# Database Configuration
POSTGRES_DB=cockpit
POSTGRES_USER=cockpit
POSTGRES_PASSWORD=cockpit123

# Redis Configuration
COCKPIT_REDIS_PASSWORD=changeme

# Redis TLS (disabled by default)
# COCKPIT_REDIS_TLS=false
# COCKPIT_REDIS_TLS_VERIFY=true
# COCKPIT_REDIS_TLS_CA_CERT=/certs/ca.crt
# COCKPIT_REDIS_TLS_CERT=/certs/client.crt
# COCKPIT_REDIS_TLS_KEY=/certs/client.key

# Nautobot Integration
NAUTOBOT_URL=http://localhost:8080
NAUTOBOT_TOKEN=your_nautobot_token_here
NAUTOBOT_TIMEOUT=30

# Security
SECRET_KEY=your-secret-key-change-this-in-production

# Credential-at-rest encryption (optional)
# Dedicated key for stored device credentials; falls back to SECRET_KEY when
# unset. Generate with: openssl rand -hex 32
# CREDENTIAL_ENCRYPTION_KEY=

# PBKDF2 iteration count for credential encryption key derivation.
# Default: 100000 (legacy, non-breaking). Recommended: 600000 — but ONLY after
# running the re-encryption migration (backend/scripts/credential_manager/rotate_key.py).
# WARNING: changing this without the migration makes stored credentials undecryptable.
# KDF_ITERATIONS=100000

# Logging
LOG_LEVEL=INFO
