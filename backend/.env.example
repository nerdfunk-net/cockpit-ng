# Cockpit Backend Configuration
# Copy this file to .env and modify the values as needed
#
# Configuration Sections:
#   - Server Configuration: Basic server settings
#   - Nautobot Configuration: Connection to Nautobot instance
#   - Authentication: JWT and initial credentials
#   - OIDC/SSO Authentication: Single Sign-On with Keycloak (see line 28)
#   - Git SSL Configuration: Custom certificates for Git
#   - File Storage: Upload and file handling settings
#   - Logging: Log level and format
#
# Quick Start for OIDC:
#   Jump to line 28 for OIDC/SSO configuration with Keycloak
#   See OIDC_SETUP.md for detailed setup instructions

# ============================================================================
# Server Configuration
# ============================================================================
# Use backend-specific variables to avoid ambiguity when running frontend/backend together
BACKEND_SERVER_HOST=127.0.0.1
BACKEND_SERVER_PORT=8000

# Legacy names (kept for reference and backward compatibility):
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8000
DEBUG=false

# ============================================================================
# Nautobot Configuration
# ============================================================================
NAUTOBOT_HOST=http://localhost:8080
NAUTOBOT_TOKEN=your-nautobot-token-here
NAUTOBOT_TIMEOUT=30

# ============================================================================
# Authentication Configuration
# ============================================================================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Initial credentials for first-time setup (used when creating the initial credential on first startup)
INITIAL_USERNAME=admin
INITIAL_PASSWORD=admin

# ============================================================================
# OIDC / SSO Authentication Configuration
# ============================================================================
# Enable OpenID Connect (OIDC) for Single Sign-On (SSO) authentication
# When enabled, users can login via "Sign in with SSO" button on login page
# Traditional username/password login remains available alongside OIDC

# Enable/Disable OIDC authentication
OIDC_ENABLED=false

# OIDC Discovery URL
# This URL provides automatic configuration for your OIDC provider
# For Keycloak: http://{host}:{port}/realms/{realm-name}/.well-known/openid-configuration
# Example: http://127.0.0.1:7080/realms/cockpit/.well-known/openid-configuration
OIDC_DISCOVERY_URL=

# OIDC Client Configuration
# Create a client in your OIDC provider (Keycloak) and configure these values:
# - Client ID: Unique identifier for your application
# - Client Secret: Secret key for authentication (keep this secure!)
# - Access Type: Must be "confidential" in Keycloak
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# OIDC Redirect URI
# The URL where users are redirected after authentication
# This must match EXACTLY what's configured in your OIDC provider
# For local development: http://localhost:3000/login/callback
# For production: https://your-domain.com/login/callback
OIDC_REDIRECT_URI=http://localhost:3000/login/callback

# OIDC Scopes (comma-separated)
# Scopes define what user information is requested from the OIDC provider
# Standard scopes:
#   - openid: Required for OIDC (provides user ID)
#   - profile: User's profile information (name, username)
#   - email: User's email address
#   - offline_access: Enables refresh tokens for extended sessions
OIDC_SCOPES=openid,profile,email,offline_access

# OIDC Claim Mapping
# These settings define which fields from the ID token are used for user information
# Different OIDC providers may use different claim names
#
# For Keycloak (recommended):
#   OIDC_CLAIM_USERNAME=preferred_username  (Keycloak login username)
#   OIDC_CLAIM_EMAIL=email                  (User's email address)
#   OIDC_CLAIM_NAME=name                    (User's full display name)
#
# Available Keycloak claims:
#   - preferred_username: User's login username (e.g., "admin", "john.doe")
#   - email: User's email address
#   - name: Full display name (e.g., "John Doe")
#   - given_name: First name only
#   - family_name: Last name only
#   - sub: Unique user ID (UUID)
#
# The username claim is used to identify users in the Cockpit database
OIDC_CLAIM_USERNAME=preferred_username
OIDC_CLAIM_EMAIL=email
OIDC_CLAIM_NAME=name

# Auto-Provision Users
# When true: New users are automatically created on first OIDC login
# When false: Users must exist in the database before they can login via OIDC
# Recommended: true for most deployments
OIDC_AUTO_PROVISION=true

# Quick Setup Guide for Keycloak:
# 1. Create a new client in Keycloak admin console
# 2. Set Client ID (e.g., "cockpit")
# 3. Set Access Type to "confidential"
# 4. Add Valid Redirect URI: http://localhost:3000/login/callback
# 5. Save and copy the Client Secret from Credentials tab
# 6. Update the values above with your Keycloak configuration
# 7. Set OIDC_ENABLED=true
# 8. Restart the backend server
# 9. The "Sign in with SSO" button will appear on the login page
#
# For detailed setup instructions, see: OIDC_SETUP.md

# ============================================================================
# Git SSL Configuration
# ============================================================================
# For self-hosted Git servers with custom certificates
GIT_SSL_VERIFY=true
# GIT_SSL_CA_INFO=/path/to/custom-ca-cert.pem
# GIT_SSL_CERT=/path/to/client-cert.pem

# ============================================================================
# File Storage Configuration
# ============================================================================
# Directory where configuration files are stored (relative to backend directory)
CONFIG_FILES_DIRECTORY=config_files

# Allowed file extensions for configuration files (comma-separated)
ALLOWED_FILE_EXTENSIONS=.txt,.conf,.cfg,.config,.ini,.yaml,.yml,.json

# Maximum file size in MB for file uploads and comparisons
MAX_FILE_SIZE_MB=10

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Database Configuration (optional, for future use)
# DATABASE_URL=postgresql://user:password@localhost/cockpit
