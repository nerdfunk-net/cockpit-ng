# Cockpit Backend Configuration
# Copy this file to .env and modify the values as needed
#
# Configuration Sections:
#   - Server Configuration: Basic server settings
#   - Nautobot Configuration: Connection to Nautobot instance
#   - Authentication: JWT and initial credentials
#   - OIDC/SSO Authentication: See config/oidc_providers.yaml for configuration
#   - File Storage: Upload and file handling settings
#   - Logging: Log level and format
#
# OIDC/SSO Configuration:
#   OIDC is now configured via YAML file (config/oidc_providers.yaml)
#   See config/oidc_providers.yaml.example for examples
#   See OIDC_SETUP.md for detailed setup instructions

# ============================================================================
# Server Configuration
# ============================================================================
# Use backend-specific variables to avoid ambiguity when running frontend/backend together
BACKEND_SERVER_HOST=127.0.0.1
BACKEND_SERVER_PORT=8000

# ============================================================================
# Nautobot Configuration
# ============================================================================
NAUTOBOT_HOST=http://localhost:8080
NAUTOBOT_TOKEN=your-nautobot-token-here
NAUTOBOT_TIMEOUT=30

# ============================================================================
# Authentication Configuration
# ============================================================================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# Credential Encryption (at-rest)
# ============================================================================
# Optional dedicated key for credential-at-rest encryption. When unset,
# SECRET_KEY is used (backward compatible). Setting it isolates stored device
# credentials from a JWT-key compromise. Generate with: openssl rand -hex 32
#
# WARNING: changing this on an existing install requires re-encrypting stored
# credentials first (scripts/credential_manager/rotate_key.py).
# CREDENTIAL_ENCRYPTION_KEY=

# PBKDF2 iteration count for the credential encryption key derivation.
# Default: 100000 (legacy value, non-breaking for existing installs).
# Recommended (OWASP 2023): 600000 — but ONLY after running the re-encryption
# migration (scripts/credential_manager/rotate_key.py).
#
# WARNING: this value is part of the encryption key. Changing or removing it
# without running rotate_key.py makes ALL stored credentials undecryptable.
# It must be identical on every process (backend, Celery worker, beat).
# KDF_ITERATIONS=100000

# Initial credentials for first-time setup (used when creating the initial credential on first startup)
INITIAL_USERNAME=admin
INITIAL_PASSWORD=admin

# ============================================================================
# File Storage Configuration
# ============================================================================
# Directory where configuration files are stored (relative to backend directory)
CONFIG_FILES_DIRECTORY=config_files

# Allowed file extensions for configuration files (comma-separated)
ALLOWED_FILE_EXTENSIONS=.txt,.conf,.cfg,.config,.ini,.yaml,.yml,.json

# Maximum file size in MB for file uploads and comparisons
MAX_FILE_SIZE_MB=10

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================================
# Redis and Celery Configuration
# ============================================================================
# Redis server configuration for Celery message broker and result backend
COCKPIT_REDIS_HOST=localhost
COCKPIT_REDIS_PORT=6379
COCKPIT_REDIS_PASSWORD=changeme

# Celery worker configuration
CELERY_MAX_WORKERS=4

# Advanced: Override Redis URL (auto-generated from REDIS_HOST, REDIS_PORT, REDIS_PASSWORD)
# REDIS_URL=redis://:password@localhost:6379/0

# Redis TLS (disabled by default)
# Set COCKPIT_REDIS_TLS=true to encrypt all Redis connections.
# COCKPIT_REDIS_TLS=false
# COCKPIT_REDIS_TLS_VERIFY=true           # Verify server certificate (set false for self-signed)
# COCKPIT_REDIS_TLS_CA_CERT=/path/to/ca.crt      # CA certificate for server verification
# COCKPIT_REDIS_TLS_CERT=/path/to/client.crt     # Client certificate (mTLS only)
# COCKPIT_REDIS_TLS_KEY=/path/to/client.key       # Client private key (mTLS only)

# ============================================================================
# Audit Log Retention
# ============================================================================
# Number of days to retain audit log entries (0 = disabled, keep forever)
# Example: PURGE_LOGS=90 keeps logs for the last 90 days
PURGE_LOGS=0

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
# PostgreSQL database connection settings
# Note: SQLite support has been removed. PostgreSQL is now required.
COCKPIT_DATABASE_HOST=localhost
COCKPIT_DATABASE_PORT=5432
COCKPIT_DATABASE_NAME=cockpit
COCKPIT_DATABASE_USERNAME=postgres
COCKPIT_DATABASE_PASSWORD=postgres
COCKPIT_DATABASE_SSL=false

# ============================================================================
# Audit Log Retention
# ============================================================================
# Number of days to retain audit log entries (0 = disabled, keep forever)
# Example: PURGE_LOGS=90 keeps logs for the last 90 days
PURGE_LOGS=5

# install certificates when startup
INSTALL_CERTIFICATE_FILES=false

# Apply safe column type changes (e.g. VARCHAR widening) on startup (default false)
APPLY_SAFE_DATABASE_MIGRATION=false
# Apply risky column changes (type casts, NOT NULL additions) on startup (default false)
APPLY_RISKY_DATABASE_MIGRATION=false
