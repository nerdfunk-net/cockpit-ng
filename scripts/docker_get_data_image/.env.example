# Copy to .env and fill in values before running docker compose.

# Redis — Cockpit server connection
REDIS_HOST=cockpit.example.com
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# Redis TLS (optional)
# REDIS_SSL=false
# REDIS_TLS_VERIFY=true
# REDIS_TLS_CA_CERT=
# REDIS_TLS_CERT=
# REDIS_TLS_KEY=

# Agent identity (leave blank to auto-detect from container hostname)
AGENT_ID=get-data-probe-01

# Required — must match the shared secret in Cockpit Settings → Agents
COCKPIT_SHARED_SECRET=

# SSH key directory on the host (mounted read-only into the container)
SSH_KEY_DIR=~/.ssh

# Pipeline config file on the host (mounted read-only at /app/config.yaml)
CONFIG_FILE=./config.yaml

# SSH / command execution
COMMAND_TIMEOUT=60
SSH_HOST_KEY_CHECKING=False

# Operational
HEARTBEAT_INTERVAL=30
LOGLEVEL=INFO
