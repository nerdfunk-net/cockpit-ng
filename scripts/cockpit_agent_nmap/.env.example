# Shared secret for HMAC authentication (required)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
COCKPIT_SHARED_SECRET=

# Redis Configuration (Cockpit Redis server)
REDIS_HOST=cockpit.example.com
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# Redis TLS (disabled by default)
# REDIS_SSL=false
# REDIS_TLS_VERIFY=true
# REDIS_TLS_CA_CERT=
# REDIS_TLS_CERT=
# REDIS_TLS_KEY=

# Logging level
LOGLEVEL=INFO

# Agent Identity (auto-detected from hostname if not set)
# AGENT_ID=nmap-probe-01

# Nmap settings
# NMAP_PATH=/usr/bin/nmap          # Auto-detected if not set
NMAP_DEFAULT_PORTS=1-1024        # Default port range when not specified in command
NMAP_DEFAULT_SCAN_TYPE=connect     # syn | connect | udp (syn/udp require root)
NMAP_SERVICE_DETECTION=false       # Enable -sV service/version detection
NMAP_TIMEOUT=300                   # Max seconds per scan

# Operational Settings
HEARTBEAT_INTERVAL=30
