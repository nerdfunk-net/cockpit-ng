[Unit]
Description=Get Data Agent for Cockpit
After=network.target

[Service]
Type=simple
User=cockpit-agent
Group=cockpit-agent
WorkingDirectory=/opt/cockpit-agent-get-data
ExecStart=/opt/cockpit-agent-get-data/venv/bin/python agent.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Environment
EnvironmentFile=/opt/cockpit-agent-get-data/.env

# Security
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
