# Redis Configuration (Cockpit Redis server)
REDIS_HOST=cockpit.example.com
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# set loglevel
LOGLEVEL=DEBUG

# Agent Identity (auto-detected from hostname if not set)
# AGENT_ID=probe-host-01

# Ping settings
PING_COUNT=3               # Number of ICMP packets sent per IP address
PING_TIMEOUT=5             # Per-ping wait timeout in seconds
PING_MAX_CONCURRENCY=50    # Max concurrent pings (limits resource usage for large device lists)

# Operational Settings
HEARTBEAT_INTERVAL=30
