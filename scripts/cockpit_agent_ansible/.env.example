# Shared secret for HMAC authentication (required)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
COCKPIT_SHARED_SECRET=

# Redis Configuration (Cockpit Redis server)
REDIS_HOST=cockpit.example.com
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# Redis TLS (disabled by default)
# REDIS_SSL=false              # Set to true to enable TLS encryption
# REDIS_TLS_VERIFY=true        # Verify server certificate (set false for self-signed certs)
# REDIS_TLS_CA_CERT=           # Path to CA certificate for server verification
# REDIS_TLS_CERT=              # Path to client certificate (mTLS only)
# REDIS_TLS_KEY=               # Path to client private key (mTLS only)

# Logging level
LOGLEVEL=DEBUG

# Agent Identity (auto-detected from hostname if not set)
# AGENT_ID=probe-host-01

# Ansible settings
ANSIBLE_PLAYBOOK_DIR=./          # Directory containing get_facts.yml (default: agent directory)
ANSIBLE_TIMEOUT=60               # Max seconds to wait for ansible-playbook to finish
ANSIBLE_HOST_KEY_CHECKING=False  # Set to True in production if known hosts are managed

# Operational Settings
HEARTBEAT_INTERVAL=30
