# Redis Configuration (Cockpit Redis server)
REDIS_HOST=cockpit.example.com
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# Logging level
LOGLEVEL=INFO

# Agent Identity (auto-detected from hostname if not set)
# AGENT_ID=netmiko-probe-01

# Shared secret for HMAC message authentication and Fernet credential encryption.
# Must match the value stored in the Cockpit settings table for this agent_id.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
COCKPIT_SHARED_SECRET=

# Netmiko settings
NETMIKO_TIMEOUT=60               # Max seconds for SSH connection + command execution
NETMIKO_HOST_KEY_CHECKING=False  # Set to True in production if known_hosts is managed

# Operational Settings
HEARTBEAT_INTERVAL=30
