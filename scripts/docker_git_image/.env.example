# Copy to .env and fill in values before running docker compose.

# Redis — Cockpit server connection
REDIS_HOST=cockpit.example.com
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# Redis TLS (optional)
# REDIS_SSL=false
# REDIS_TLS_VERIFY=true
# REDIS_TLS_CA_CERT=
# REDIS_TLS_CERT=
# REDIS_TLS_KEY=

# Agent identity (leave blank to auto-detect from container hostname)
AGENT_ID=git-agent-01

# Required — must match the shared secret in Cockpit Settings → Agents
COCKPIT_SHARED_SECRET=

# Host path of the git repo (mounted into the container)
GIT_REPO_HOST_PATH=/opt/app/config

# Path inside the container (must match the mount target and agent whitelist)
GIT_REPO_PATH=/opt/app/config

# Container on the host Docker daemon to restart (via mounted docker.sock)
DOCKER_CONTAINER_NAME=app

# Optional SSH keys for git pull over SSH remotes
SSH_KEY_DIR=~/.ssh

# Timeouts
COMMAND_TIMEOUT=30
DOCKER_TIMEOUT=60

# Operational
HEARTBEAT_INTERVAL=30
LOGLEVEL=INFO
